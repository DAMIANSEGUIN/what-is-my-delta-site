{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    { "source": "/(index|404|500).html", "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}